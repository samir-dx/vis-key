{
  "manifest_version": 3,
  "name": "Visualize Keystrokes",
  "version": "1.0.0",
  "description": "Displays real-time keypresses with a terminal-inspired HUD.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
        "128": "icon.png"
    }
  },
  "permissions": [
    "storage"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}